{
  "id": "pok-role-system",
  "title": "Pok\u00E9 Role System",
  "description": "MVP Foundry VTT v13 system scaffold for PokeRole 2.0 inspired campaigns.",
  "version": "0.20.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "url": "https://github.com/RiccardoMont1/Pok-Role-Module",
  "manifest": "https://raw.githubusercontent.com/RiccardoMont1/Pok-Role-Module/main/system.json",
  "download": "https://github.com/RiccardoMont1/Pok-Role-Module/archive/refs/heads/main.zip",
  "authors": [
    {
      "name": "Pok-Role-Module Contributors"
    }
  ],
  "esmodules": [
    "pok-role-module.mjs"
  ],
  "styles": [
    "styles/pok-role-module.css"
  ],
  "packs": [
    {
      "name": "trainer-items",
      "label": "Trainer Items",
      "system": "pok-role-system",
      "path": "packs/trainer-items",
      "type": "Item",
      "private": false
    },
    {
      "name": "healing-items",
      "label": "Healing Items",
      "system": "pok-role-system",
      "path": "packs/healing-items",
      "type": "Item",
      "private": false
    },
    {
      "name": "pokemon-care-items",
      "label": "Pokemon Care Items",
      "system": "pok-role-system",
      "path": "packs/pokemon-care-items",
      "type": "Item",
      "private": false
    },
    {
      "name": "evolutionary-items",
      "label": "Evolutionary Items",
      "system": "pok-role-system",
      "path": "packs/evolutionary-items",
      "type": "Item",
      "private": false
    },
    {
      "name": "held-items",
      "label": "Held Items",
      "system": "pok-role-system",
      "path": "packs/held-items",
      "type": "Item",
      "private": false
    },
    {
      "name": "moves",
      "label": "Moves",
      "system": "pok-role-system",
      "path": "packs/moves",
      "type": "Item",
      "private": false
    },
    {
      "name": "pokedex",
      "label": "Pokedex",
      "system": "pok-role-system",
      "path": "packs/pokedex",
      "type": "Item",
      "private": false
    },
    {
      "name": "pokemon-actors",
      "label": "Pokemon Actors",
      "system": "pok-role-system",
      "path": "packs/pokemon-actors",
      "type": "Actor",
      "private": false
    },
    {
      "name": "weather-conditions",
      "label": "Weather Conditions",
      "system": "pok-role-system",
      "path": "packs/weather-conditions",
      "type": "Item",
      "private": false
    },
    {
      "name": "pokemon-status",
      "label": "Pokemon Status",
      "system": "pok-role-system",
      "path": "packs/pokemon-status",
      "type": "Item",
      "private": false
    },
    {
      "name": "abilities",
      "label": "Abilities",
      "system": "pok-role-system",
      "path": "packs/abilities",
      "type": "Item",
      "private": false
    }
  ],
  "packFolders": [
    {
      "name": "PokeRole Compendia",
      "sorting": "m",
      "color": "#d2553d",
      "packs": [],
      "folders": [
        {
          "name": "Trainer Gear",
          "sorting": "m",
          "color": "#318f84",
          "packs": [
            "trainer-items",
            "healing-items",
            "pokemon-care-items",
            "evolutionary-items",
            "held-items"
          ]
        },
        {
          "name": "Battle Rules",
          "sorting": "m",
          "color": "#4d5c7a",
          "packs": [
            "moves",
            "abilities",
            "weather-conditions",
            "pokemon-status"
          ]
        },
        {
          "name": "Pokedex & Lore",
          "sorting": "m",
          "color": "#7c5b95",
          "packs": [
            "pokedex",
            "pokemon-actors"
          ]
        }
      ]
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "it",
      "name": "Italiano",
      "path": "lang/it.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "trainer": {},
      "pokemon": {}
    },
    "Item": {
      "move": {},
      "gear": {},
      "ability": {},
      "weather": {},
      "status": {},
      "pokedex": {}
    }
  },
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "resources.hp",
  "secondaryTokenAttribute": "resources.will",
  "initiative": "1d6 + @attributes.dexterity + @skills.alert"
}
