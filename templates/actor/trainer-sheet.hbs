<form class="{{cssClass}} pok-role-sheet trainer-sheet" autocomplete="off">
  <div class="trainer-sheet-shell">
    <nav class="trainer-view-nav" aria-label="{{localize 'POKROLE.Trainer.ActiveEffects'}}">
      <button
        type="button"
        class="trainer-view-button is-active"
        data-action="switch-trainer-tab"
        data-tab="main"
        title="{{localize 'POKROLE.Trainer.MainSheetTab'}}"
        aria-label="{{localize 'POKROLE.Trainer.MainSheetTab'}}"
      >
        <i class="fas fa-id-card"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Trainer.MainSheetTab"}}</span>
      </button>
      <button
        type="button"
        class="trainer-view-button"
        data-action="switch-trainer-tab"
        data-tab="effects"
        title="{{localize 'POKROLE.Effects.Tab'}}"
        aria-label="{{localize 'POKROLE.Effects.Tab'}}"
      >
        <i class="fas fa-wand-magic-sparkles"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Effects.Tab"}}</span>
      </button>
      <button
        type="button"
        class="trainer-view-button"
        data-action="switch-trainer-tab"
        data-tab="bio"
        title="{{localize 'POKROLE.Trainer.BioTab'}}"
        aria-label="{{localize 'POKROLE.Trainer.BioTab'}}"
      >
        <i class="fas fa-scroll"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Trainer.BioTab"}}</span>
      </button>
    </nav>

    <div class="trainer-view-content">
      <div class="trainer-view-panel is-active" data-tab="main">
  <section class="trainer-top">
    <aside class="trainer-portrait-card">
      <div class="trainer-photo-frame">
        <img
          class="profile-img"
          src="{{actor.img}}"
          data-edit="img"
          title="{{actor.name}}"
        />
      </div>
      <div class="trainer-quick-actions">
        <button type="button" data-action="roll-initiative">
          <i class="fas fa-bolt"></i>
          {{localize "POKROLE.Actions.RollInitiative"}}
        </button>
        <button type="button" data-action="roll-combined">
          <i class="fas fa-dice"></i>
          {{localize "POKROLE.Actions.RollCombined"}}
        </button>
        <button type="button" data-action="reset-action-counter">
          <i class="fas fa-rotate-left"></i>
          {{localize "POKROLE.Actions.ResetActionCounter"}}
        </button>
      </div>
    </aside>

    <section class="trainer-identity-card">
      <header class="trainer-banner">
        <h1>POKEMON LEAGUE</h1>
        <label>
          <span>{{localize "POKROLE.Trainer.CardRank"}}</span>
          <select name="system.cardRank">
            {{selectOptions trainerRankOptions selected=system.cardRank localize=true}}
          </select>
        </label>
      </header>

      <div class="trainer-identity-grid">
        <label>
          <span>{{localize "POKROLE.Fields.Name"}}</span>
          <input
            name="name"
            type="text"
            value="{{actor.name}}"
            placeholder="{{localize 'POKROLE.Fields.Name'}}"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Age"}}</span>
          <input
            type="number"
            name="system.age"
            value="{{system.age}}"
            min="0"
            max="120"
            data-dtype="Number"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Player"}}</span>
          <input
            type="text"
            name="system.player"
            value="{{system.player}}"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Concept"}}</span>
          <input
            type="text"
            name="system.concept"
            value="{{system.concept}}"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Nature"}}</span>
          <input
            type="text"
            name="system.nature"
            value="{{system.nature}}"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Money"}}</span>
          <input
            type="number"
            name="system.money"
            value="{{system.money}}"
            min="0"
            data-dtype="Number"
          />
        </label>
      </div>

      <div class="trainer-status-grid">
        <label>
          <span>{{localize "POKROLE.Resources.HP"}}</span>
          <div class="pair-input">
            <input
              type="number"
              name="system.resources.hp.value"
              value="{{system.resources.hp.value}}"
              min="0"
              data-dtype="Number"
            />
            <span>/</span>
            <input
              type="number"
              name="system.resources.hp.max"
              value="{{system.resources.hp.max}}"
              min="1"
              data-dtype="Number"
            />
          </div>
        </label>
        <label>
          <span>{{localize "POKROLE.Resources.Will"}}</span>
          <div class="pair-input">
            <input
              type="number"
              name="system.resources.will.value"
              value="{{system.resources.will.value}}"
              min="0"
              data-dtype="Number"
            />
            <span>/</span>
            <input
              type="number"
              name="system.resources.will.max"
              value="{{system.resources.will.max}}"
              min="1"
              data-dtype="Number"
            />
          </div>
        </label>
        <label class="badges-field">
          <span>{{localize "POKROLE.Trainer.Badges"}}</span>
          <input
            type="hidden"
            name="system.badges"
            value="{{system.badges}}"
            data-dtype="Number"
          />
          <div class="track-bar compact badges-track">
            {{#each badgesTrack.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.badges"
              data-track-value="{{slot.value}}"
              data-track-min="{{../badgesTrack.min}}"
              data-track-max="{{../badgesTrack.max}}"
              title="{{localize 'POKROLE.Trainer.Badges'}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
        </label>
        <label class="trainer-pokedex-field">
          <span>{{localize "POKROLE.Trainer.SeenCaught"}}</span>
          <div class="pair-input">
            <input
              type="number"
              name="system.pokedex.seen"
              value="{{system.pokedex.seen}}"
              min="0"
              data-dtype="Number"
            />
            <span>/</span>
            <input
              type="number"
              name="system.pokedex.caught"
              value="{{system.pokedex.caught}}"
              min="0"
              data-dtype="Number"
            />
          </div>
        </label>
      </div>

      <p class="inline-meta">
        <strong>{{localize "POKROLE.Combat.InitiativeScore"}}:</strong> {{initiativeScore}}
        |
        <strong>{{localize "POKROLE.Combat.BaseInitiativeScore"}}:</strong> {{baseInitiativeScore}}
        |
        <strong>{{localize "POKROLE.Combat.PainPenalty"}}:</strong> -{{painPenalty}}
        |
        <strong>{{localize "POKROLE.Combat.ActionNumber"}}:</strong>
        <input
          class="action-inline-input"
          type="number"
          name="system.combat.actionNumber"
          value="{{system.combat.actionNumber}}"
          min="1"
          max="5"
          data-dtype="Number"
        />
      </p>
    </section>
  </section>

  <section class="trainer-main-grid">
    <section class="sheet-section trainer-stat-panel trainer-attributes-panel">
      <h2>{{localize "POKROLE.Attributes.Title"}}</h2>
      <div class="trainer-attribute-zones">
        <section class="trait-zone">
          <h3>{{localize "POKROLE.Attributes.PhysicalMental"}}</h3>
          <div class="trainer-stat-list">
            {{#each trainerPhysicalMentalAttributes as |attribute|}}
            <div class="trainer-stat-row">
              <label>{{localize attribute.label}}</label>
              <input
                type="hidden"
                name="{{attribute.fieldPath}}"
                value="{{attribute.value}}"
                data-dtype="Number"
              />
              <div class="track-bar compact">
                {{#each attribute.track.slots as |slot|}}
                <button
                  type="button"
                  class="track-box {{#if slot.active}}is-active{{/if}}"
                  data-action="set-track"
                  data-track-field="{{../fieldPath}}"
                  data-track-value="{{slot.value}}"
                  data-track-min="{{../track.min}}"
                  data-track-max="{{../track.max}}"
                  title="{{localize ../label}} {{slot.value}}"
                ></button>
                {{/each}}
              </div>
              <button
                type="button"
                class="icon-button"
                data-action="roll-attribute"
                data-attribute="{{attribute.key}}"
                title="{{localize 'POKROLE.Actions.RollAttribute'}}"
              >
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </section>

        <section class="trait-zone">
          <h3>{{localize "POKROLE.Attributes.Social"}}</h3>
          <div class="trainer-stat-list">
            {{#each trainerSocialAttributes as |attribute|}}
            <div class="trainer-stat-row">
              <label>{{localize attribute.label}}</label>
              <input
                type="hidden"
                name="{{attribute.fieldPath}}"
                value="{{attribute.value}}"
                data-dtype="Number"
              />
              <div class="track-bar compact">
                {{#each attribute.track.slots as |slot|}}
                <button
                  type="button"
                  class="track-box {{#if slot.active}}is-active{{/if}}"
                  data-action="set-track"
                  data-track-field="{{../fieldPath}}"
                  data-track-value="{{slot.value}}"
                  data-track-min="{{../track.min}}"
                  data-track-max="{{../track.max}}"
                  title="{{localize ../label}} {{slot.value}}"
                ></button>
                {{/each}}
              </div>
              <button
                type="button"
                class="icon-button"
                data-action="roll-attribute"
                data-attribute="{{attribute.key}}"
                title="{{localize 'POKROLE.Actions.RollAttribute'}}"
              >
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </section>
      </div>
    </section>

    <section class="sheet-section trainer-stat-panel trainer-skills-panel">
      <h2>{{localize "POKROLE.Skills.Title"}}</h2>
      <div class="trainer-stat-list">
        {{#each skillDefinitions as |skill|}}
        <div class="trainer-stat-row">
          <label>{{localize skill.label}}</label>
          <input
            type="hidden"
            name="system.skills.{{skill.key}}"
            value="{{skill.value}}"
            data-dtype="Number"
          />
          <div class="track-bar compact">
            {{#each skill.track.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.skills.{{../key}}"
              data-track-value="{{slot.value}}"
              data-track-min="{{../track.min}}"
              data-track-max="{{../track.max}}"
              title="{{localize ../label}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
          <button
            type="button"
            class="icon-button"
            data-action="roll-skill"
            data-skill="{{skill.key}}"
            title="{{localize 'POKROLE.Actions.RollSkill'}}"
          >
            <i class="fas fa-dice"></i>
          </button>
        </div>
        {{/each}}
      </div>

      <div class="trainer-extra-inline">
        <div class="section-title-row">
          <h3>{{localize "POKROLE.Trainer.ExtraSkills"}}</h3>
          <button type="button" data-action="add-extra-skill">
            <i class="fas fa-plus"></i>
            {{localize "POKROLE.Trainer.AddExtra"}}
          </button>
        </div>
        {{#if extraSkills.length}}
        <div class="trainer-extra-list">
          {{#each extraSkills as |extra|}}
          <div class="trainer-extra-row">
            <input
              type="text"
              name="system.extraSkills.{{extra.index}}.name"
              value="{{extra.name}}"
              placeholder="{{localize 'POKROLE.Trainer.ExtraName'}}"
            />
            <input
              type="hidden"
              name="system.extraSkills.{{extra.index}}.value"
              value="{{extra.value}}"
              data-dtype="Number"
            />
            <div class="track-bar compact">
              {{#each extra.track.slots as |slot|}}
              <button
                type="button"
                class="track-box {{#if slot.active}}is-active{{/if}}"
                data-action="set-track"
                data-track-field="system.extraSkills.{{../index}}.value"
                data-track-value="{{slot.value}}"
                data-track-min="{{../track.min}}"
                data-track-max="{{../track.max}}"
                title="{{../name}} {{slot.value}}"
              ></button>
              {{/each}}
            </div>
            <button
              type="button"
              class="icon-button danger"
              data-action="delete-extra-skill"
              data-extra-index="{{extra.index}}"
              title="{{localize 'POKROLE.Actions.Delete'}}"
            >
              <i class="fas fa-trash"></i>
            </button>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="empty-state">{{localize "POKROLE.Trainer.NoExtraSkills"}}</p>
        {{/if}}
      </div>
    </section>

    <section class="sheet-section trainer-inventory-panel">
      <div class="section-title-row">
        <h2>{{localize "POKROLE.Trainer.InventoryTitle"}}</h2>
        <button type="button" class="inventory-add-button" data-action="create-gear">
          <i class="fas fa-plus"></i>
          {{localize "POKROLE.Actions.NewGear"}}
        </button>
      </div>

      <div class="trainer-inventory-columns">
        <section class="gear-pocket-panel is-battle">
          <header>
            <h3>{{localize "POKROLE.Trainer.InventoryBattle"}}</h3>
            <small>{{localize "POKROLE.Trainer.InventoryBattleHint"}}</small>
          </header>
          {{#if gearBattleItems.length}}
          <div class="gear-table-wrap">
          <table class="moves-table gear-table">
            <thead>
              <tr>
                <th>{{localize "POKROLE.Gear.Name"}}</th>
                <th>{{localize "POKROLE.Gear.Pocket.Label"}}</th>
                <th>{{localize "POKROLE.Gear.Stock"}}</th>
                <th>{{localize "POKROLE.Gear.Effects"}}</th>
                <th>{{localize "POKROLE.Common.Actions"}}</th>
              </tr>
            </thead>
            <tbody>
              {{#each gearBattleItems as |gear|}}
              <tr data-item-id="{{gear.id}}">
                <td class="move-name">
                  <img src="{{gear.img}}" title="{{gear.name}}" />
                  <span>{{gear.name}}</span>
                </td>
                <td>
                  <span class="pocket-chip pocket-{{gear.pocketKey}}">{{gear.pocketLabel}}</span>
                </td>
                <td>{{gear.stockLabel}}</td>
                <td>{{gear.effectsSummary}}</td>
                <td class="move-actions">
                  <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                    <i class="fas fa-hand-sparkles"></i>
                  </button>
                  <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                    <i class="fas fa-pen"></i>
                  </button>
                  <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          </div>
          {{else}}
          <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
          {{/if}}
        </section>

        <section class="gear-pocket-panel is-field">
          <header>
            <h3>{{localize "POKROLE.Trainer.InventoryField"}}</h3>
            <small>{{localize "POKROLE.Trainer.InventoryFieldHint"}}</small>
          </header>
          {{#if gearFieldItems.length}}
          <div class="gear-table-wrap">
          <table class="moves-table gear-table">
            <thead>
              <tr>
                <th>{{localize "POKROLE.Gear.Name"}}</th>
                <th>{{localize "POKROLE.Gear.Pocket.Label"}}</th>
                <th>{{localize "POKROLE.Gear.Stock"}}</th>
                <th>{{localize "POKROLE.Gear.Effects"}}</th>
                <th>{{localize "POKROLE.Common.Actions"}}</th>
              </tr>
            </thead>
            <tbody>
              {{#each gearFieldItems as |gear|}}
              <tr data-item-id="{{gear.id}}">
                <td class="move-name">
                  <img src="{{gear.img}}" title="{{gear.name}}" />
                  <span>{{gear.name}}</span>
                </td>
                <td>
                  <span class="pocket-chip pocket-{{gear.pocketKey}}">{{gear.pocketLabel}}</span>
                </td>
                <td>{{gear.stockLabel}}</td>
                <td>{{gear.effectsSummary}}</td>
                <td class="move-actions">
                  <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                    <i class="fas fa-hand-sparkles"></i>
                  </button>
                  <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                    <i class="fas fa-pen"></i>
                  </button>
                  <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          </div>
          {{else}}
          <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
          {{/if}}
        </section>
      </div>
    </section>
  </section>
      </div>

      <div class="trainer-view-panel" data-tab="effects">
  <section class="sheet-section trainer-conditions-panel">
    <h2>{{localize "POKROLE.Conditions.QuickTitle"}}</h2>
    <div class="condition-chip-grid">
      {{#each conditionChips as |condition|}}
      <button
        type="button"
        class="condition-chip {{#if condition.active}}is-active{{/if}}"
        data-action="toggle-condition-chip"
        data-condition-key="{{condition.key}}"
      >
        <img src="{{condition.icon}}" alt="{{localize condition.labelPath}}" />
        <span>{{localize condition.labelPath}}</span>
      </button>
      {{/each}}
    </div>
  </section>

  <section class="sheet-section actor-effects-panel">
    <div class="section-title-row">
      <h2>{{localize "POKROLE.Effects.ConfiguredTitle"}}</h2>
      <div class="button-row">
        <button type="button" data-action="add-actor-effect">
          <i class="fas fa-plus"></i>
          {{localize "POKROLE.Effects.Add"}}
        </button>
        <button type="button" data-action="save-actor-effects">
          <i class="fas fa-floppy-disk"></i>
          {{localize "POKROLE.Effects.Save"}}
        </button>
      </div>
    </div>
    {{#if actorConfiguredEffects.length}}
    <div class="actor-effect-list">
      {{#each actorConfiguredEffects as |effect|}}
      <article class="actor-effect-row" data-effect-id="{{effect.id}}">
        <label>
          <span>{{localize "POKROLE.Move.Secondary.Label"}}</span>
          <input type="text" value="{{effect.label}}" data-effect-field="label" />
        </label>
        <label>
          <span>{{localize "POKROLE.Move.Secondary.Trigger.Label"}}</span>
          <select data-effect-field="trigger">
            {{selectOptions ../effectTriggerOptions selected=effect.trigger localize=true}}
          </select>
        </label>
        <label>
          <span>{{localize "POKROLE.Move.Secondary.Chance"}}</span>
          <input type="number" value="{{effect.chance}}" min="0" max="100" data-effect-field="chance" />
        </label>
        <label>
          <span>{{localize "POKROLE.Move.Secondary.Target.Label"}}</span>
          <select data-effect-field="target">
            {{selectOptions ../effectTargetOptions selected=effect.target localize=true}}
          </select>
        </label>
        <label>
          <span>{{localize "POKROLE.Move.Secondary.Type.Label"}}</span>
          <select data-effect-field="effectType">
            {{selectOptions ../effectTypeOptions selected=effect.effectType localize=true}}
          </select>
        </label>
        <label data-effect-visible="duration" class="{{#unless effect.showDurationField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Duration.Mode.Label"}}</span>
          <select data-effect-field="durationMode">
            {{selectOptions ../effectDurationModeOptions selected=effect.durationMode localize=true}}
          </select>
        </label>
        <label data-effect-visible="duration" class="{{#unless effect.showDurationField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Duration.Rounds"}}</span>
          <input type="number" value="{{effect.durationRounds}}" min="1" max="99" data-effect-field="durationRounds" />
        </label>
        <label data-effect-visible="condition" class="{{#unless effect.showConditionField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Condition.Label"}}</span>
          <select data-effect-field="condition">
            {{selectOptions ../effectConditionOptions selected=effect.condition localize=true}}
          </select>
        </label>
        <label data-effect-visible="stat" class="{{#unless effect.showStatField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Stat.Label"}}</span>
          <select data-effect-field="stat">
            {{selectOptions ../effectStatOptions selected=effect.stat localize=true}}
          </select>
        </label>
        <label data-effect-visible="amount" class="{{#unless effect.showAmountField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Amount"}}</span>
          <input type="number" value="{{effect.amount}}" min="-99" max="99" data-effect-field="amount" />
        </label>
        <label data-effect-visible="notes" class="{{#unless effect.showNotesField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Move.Secondary.Notes"}}</span>
          <input type="text" value="{{effect.notes}}" data-effect-field="notes" />
        </label>
        <label class="checkbox-row effect-passive-toggle">
          <input type="checkbox" data-effect-field="passive" {{checked effect.passive}} />
          <span>{{localize "POKROLE.Effects.Passive"}}</span>
        </label>
        <label>
          <span>{{localize "POKROLE.Effects.PassiveTrigger.Label"}}</span>
          <select data-effect-field="passiveTrigger">
            {{selectOptions ../effectPassiveTriggerOptions selected=effect.passiveTrigger localize=true}}
          </select>
        </label>
        <label data-effect-visible="passiveCondition" class="{{#unless effect.showPassiveConditionField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Effects.PassiveTrigger.Condition"}}</span>
          <select data-effect-field="passiveCondition">
            {{selectOptions ../effectConditionOptions selected=effect.passiveCondition localize=true}}
          </select>
        </label>
        <label data-effect-visible="passiveThreshold" class="{{#unless effect.showPassiveThresholdField}}is-hidden{{/unless}}">
          <span>{{localize "POKROLE.Effects.PassiveTrigger.Threshold"}}</span>
          <input type="number" value="{{effect.passiveThreshold}}" min="1" max="99" data-effect-field="passiveThreshold" />
        </label>
        <div class="move-actions">
          <button type="button" class="icon-button" data-action="apply-actor-effect" data-effect-id="{{effect.id}}" title="{{localize 'POKROLE.Effects.Apply'}}">
            <i class="fas fa-bolt"></i>
          </button>
          <button type="button" class="icon-button danger" data-action="delete-actor-effect" data-effect-id="{{effect.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </article>
      {{/each}}
    </div>
    {{else}}
    <p class="empty-state">{{localize "POKROLE.Effects.Empty"}}</p>
    {{/if}}
  </section>

  <section class="sheet-section actor-effects-panel">
    <h2>{{localize "POKROLE.Effects.ExternalTitle"}}</h2>
    <div class="temporary-effects-list">
      {{#if embeddedEffects.length}}
      {{#each embeddedEffects as |effect|}}
      <article class="temporary-effect-row">
        <div class="temporary-effect-main">
          <strong>{{effect.name}}</strong>
          <small>{{effect.durationLabel}} | {{effect.statuses}}</small>
          <small>{{effect.origin}}</small>
        </div>
        <div class="move-actions">
          <button
            type="button"
            class="icon-button"
            data-action="edit-embedded-effect"
            data-effect-id="{{effect.id}}"
            title="{{localize 'POKROLE.Actions.Edit'}}"
          >
            <i class="fas fa-pen"></i>
          </button>
          <button
            type="button"
            class="icon-button danger"
            data-action="delete-embedded-effect"
            data-effect-id="{{effect.id}}"
            title="{{localize 'POKROLE.Actions.Delete'}}"
          >
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </article>
      {{/each}}
      {{else}}
      <p class="empty-state">{{localize "POKROLE.Effects.ExternalEmpty"}}</p>
      {{/if}}
    </div>
  </section>

  <section class="sheet-section trainer-conditions-panel">
    <h2>{{localize "POKROLE.TemporaryEffects.Title"}}</h2>
    <div class="temporary-effects-list">
      {{#if temporaryEffects.length}}
      {{#each temporaryEffects as |effect|}}
      <article class="temporary-effect-row">
        <div class="temporary-effect-main">
          <strong>{{effect.label}}</strong>
          <small>{{effect.sourceLabel}} | {{effect.durationLabel}}</small>
        </div>
        <button
          type="button"
          class="icon-button danger temporary-effect-remove"
          data-action="remove-temporary-effect"
          data-effect-id="{{effect.id}}"
          title="{{localize 'POKROLE.TemporaryEffects.Remove'}}"
        >
          <i class="fas fa-trash"></i>
        </button>
      </article>
      {{/each}}
      {{else}}
      <p class="empty-state">{{localize "POKROLE.TemporaryEffects.None"}}</p>
      {{/if}}
    </div>
  </section>
      </div>

      <div class="trainer-view-panel" data-tab="bio">
  <section class="sheet-section trainer-bio-panel">
    <h2>{{localize "POKROLE.Trainer.InfoTitle"}}</h2>
    <div class="trainer-identity-grid">
      <label>
        <span>{{localize "POKROLE.Trainer.Role"}}</span>
        <input type="text" name="system.role" value="{{system.role}}" placeholder="{{localize 'POKROLE.Trainer.RolePlaceholder'}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Player"}}</span>
        <input type="text" name="system.player" value="{{system.player}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Concept"}}</span>
        <input type="text" name="system.concept" value="{{system.concept}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Nature"}}</span>
        <input type="text" name="system.nature" value="{{system.nature}}" />
      </label>
    </div>
  </section>

  <section class="sheet-section trainer-bio-panel">
    <h2>{{localize "POKROLE.Common.Biography"}}</h2>
    <textarea
      name="system.biography"
      rows="12"
      placeholder="{{localize 'POKROLE.Common.BiographyPlaceholder'}}"
    >{{system.biography}}</textarea>
  </section>
      </div>
    </div>
  </div>
</form>
