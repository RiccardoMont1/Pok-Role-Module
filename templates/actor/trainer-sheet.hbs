<form class="{{cssClass}} pok-role-sheet trainer-sheet" autocomplete="off">
  <section class="trainer-card-layout">
    <div class="trainer-card-left">
      <div class="trainer-photo-frame">
        <img
          class="profile-img"
          src="{{actor.img}}"
          data-edit="img"
          title="{{actor.name}}"
        />
      </div>
      <label class="trainer-nameplate">
        <span>{{localize "POKROLE.Fields.Name"}}</span>
        <input
          name="name"
          type="text"
          value="{{actor.name}}"
          placeholder="{{localize 'POKROLE.Fields.Name'}}"
        />
      </label>
      <div class="trainer-quick-actions">
        <button type="button" data-action="roll-initiative">
          <i class="fas fa-bolt"></i>
          {{localize "POKROLE.Actions.RollInitiative"}}
        </button>
        <button type="button" data-action="roll-combined">
          <i class="fas fa-dice"></i>
          {{localize "POKROLE.Actions.RollCombined"}}
        </button>
        <button type="button" data-action="reset-action-counter">
          <i class="fas fa-rotate-left"></i>
          {{localize "POKROLE.Actions.ResetActionCounter"}}
        </button>
      </div>
    </div>

    <div class="trainer-card-right">
      <header class="league-header">
        <h1>POKEMON LEAGUE</h1>
        <label>
          <span>{{localize "POKROLE.Trainer.CardRank"}}</span>
          <input
            type="hidden"
            name="system.level"
            value="{{system.level}}"
            data-dtype="Number"
          />
          <div class="track-bar">
            {{#each levelTrack.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.level"
              data-track-value="{{slot.value}}"
              data-track-min="{{../levelTrack.min}}"
              data-track-max="{{../levelTrack.max}}"
              title="{{localize 'POKROLE.Trainer.CardRank'}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
        </label>
      </header>

      <div class="trainer-meta-grid">
        <label>
          <span>{{localize "POKROLE.Trainer.Role"}}</span>
          <input
            type="text"
            name="system.role"
            value="{{system.role}}"
            placeholder="{{localize 'POKROLE.Trainer.RolePlaceholder'}}"
          />
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Money"}}</span>
          <input
            type="hidden"
            name="system.money"
            value="{{system.money}}"
            data-dtype="Number"
          />
          <div class="track-bar">
            {{#each moneyTrack.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.money"
              data-track-value="{{slot.value}}"
              data-track-min="{{../moneyTrack.min}}"
              data-track-max="{{../moneyTrack.max}}"
              title="{{localize 'POKROLE.Trainer.Money'}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
        </label>
        <label>
          <span>{{localize "POKROLE.Trainer.Badges"}}</span>
          <input
            type="hidden"
            name="system.badges"
            value="{{system.badges}}"
            data-dtype="Number"
          />
          <div class="track-bar">
            {{#each badgesTrack.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.badges"
              data-track-value="{{slot.value}}"
              data-track-min="{{../badgesTrack.min}}"
              data-track-max="{{../badgesTrack.max}}"
              title="{{localize 'POKROLE.Trainer.Badges'}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
        </label>
        <label>
          <span>{{localize "POKROLE.Combat.ActionNumber"}}</span>
          <input
            type="hidden"
            name="system.combat.actionNumber"
            value="{{system.combat.actionNumber}}"
            data-dtype="Number"
          />
          <div class="track-bar">
            {{#each actionTrack.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.combat.actionNumber"
              data-track-value="{{slot.value}}"
              data-track-min="{{../actionTrack.min}}"
              data-track-max="{{../actionTrack.max}}"
              title="{{localize 'POKROLE.Combat.ActionNumber'}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
        </label>
      </div>

      <div class="trainer-bars">
        <label>
          <span>{{localize "POKROLE.Resources.HP"}}</span>
          <div class="pair-input">
            <input
              type="number"
              name="system.resources.hp.value"
              value="{{system.resources.hp.value}}"
              min="0"
              data-dtype="Number"
            />
            <span>/</span>
            <input
              type="number"
              name="system.resources.hp.max"
              value="{{system.resources.hp.max}}"
              min="1"
              data-dtype="Number"
            />
          </div>
        </label>
        <label>
          <span>{{localize "POKROLE.Resources.Will"}}</span>
          <div class="pair-input">
            <input
              type="number"
              name="system.resources.will.value"
              value="{{system.resources.will.value}}"
              min="0"
              data-dtype="Number"
            />
            <span>/</span>
            <input
              type="number"
              name="system.resources.will.max"
              value="{{system.resources.will.max}}"
              min="1"
              data-dtype="Number"
            />
          </div>
        </label>
      </div>

      <p class="inline-meta">
        <strong>{{localize "POKROLE.Combat.InitiativeScore"}}:</strong>
        {{initiativeScore}}
        ({{localize "POKROLE.Combat.BaseInitiativeScore"}}: {{baseInitiativeScore}})
        |
        <strong>{{localize "POKROLE.Combat.PainPenalty"}}:</strong>
        -{{painPenalty}}
      </p>
    </div>
  </section>

  <section class="trainer-bottom-layout">
    <section class="sheet-section trainer-attributes-panel">
      <h2>{{localize "POKROLE.Attributes.Title"}}</h2>
      <div class="attribute-grid">
        {{#each attributeDefinitions as |attribute|}}
        <div class="attribute-row">
          <label>
            {{localize attribute.label}}
          </label>
          <input
            type="hidden"
            name="system.attributes.{{attribute.key}}"
            value="{{attribute.value}}"
            data-dtype="Number"
          />
          <div class="track-bar compact">
            {{#each attribute.track.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.attributes.{{../key}}"
              data-track-value="{{slot.value}}"
              data-track-min="{{../track.min}}"
              data-track-max="{{../track.max}}"
              title="{{localize ../label}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
          <button
            type="button"
            class="icon-button"
            data-action="roll-attribute"
            data-attribute="{{attribute.key}}"
            title="{{localize 'POKROLE.Actions.RollAttribute'}}"
          >
            <i class="fas fa-dice-d20"></i>
          </button>
        </div>
        {{/each}}
      </div>
    </section>

    <section class="sheet-section trainer-skills-panel">
      <h2>{{localize "POKROLE.Skills.Title"}}</h2>
      <div class="attribute-grid">
        {{#each skillDefinitions as |skill|}}
        <div class="attribute-row">
          <label>
            {{localize skill.label}}
          </label>
          <input
            type="hidden"
            name="system.skills.{{skill.key}}"
            value="{{skill.value}}"
            data-dtype="Number"
          />
          <div class="track-bar compact">
            {{#each skill.track.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.skills.{{../key}}"
              data-track-value="{{slot.value}}"
              data-track-min="{{../track.min}}"
              data-track-max="{{../track.max}}"
              title="{{localize ../label}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
          <button
            type="button"
            class="icon-button"
            data-action="roll-skill"
            data-skill="{{skill.key}}"
            title="{{localize 'POKROLE.Actions.RollSkill'}}"
          >
            <i class="fas fa-dice"></i>
          </button>
        </div>
        {{/each}}
      </div>
    </section>

    <section class="trainer-side-column">
      <section class="sheet-section trainer-inventory-panel">
        <div class="section-title-row">
          <h2>{{localize "POKROLE.Trainer.InventoryTitle"}}</h2>
          <button type="button" data-action="create-gear">
            <i class="fas fa-plus"></i>
            {{localize "POKROLE.Actions.NewGear"}}
          </button>
        </div>
        {{#if gearItems.length}}
        <table class="moves-table gear-table">
          <thead>
            <tr>
              <th>{{localize "POKROLE.Gear.Name"}}</th>
              <th>{{localize "POKROLE.Gear.Category.Label"}}</th>
              <th>{{localize "POKROLE.Gear.Pocket.Label"}}</th>
              <th>{{localize "POKROLE.Gear.Stock"}}</th>
              <th>{{localize "POKROLE.Gear.Effects"}}</th>
              <th>{{localize "POKROLE.Common.Actions"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each gearItems as |gear|}}
            <tr data-item-id="{{gear.id}}">
              <td class="move-name">
                <img src="{{gear.img}}" title="{{gear.name}}" />
                <span>{{gear.name}}</span>
              </td>
              <td>{{gear.categoryLabel}}</td>
              <td>{{gear.pocketLabel}}</td>
              <td>{{gear.stockLabel}}</td>
              <td>{{gear.effectsSummary}}</td>
              <td class="move-actions">
                <button type="button" data-action="use-gear" data-item-id="{{gear.id}}">
                  <i class="fas fa-hand-sparkles"></i>
                  {{localize "POKROLE.Actions.Use"}}
                </button>
                <button type="button" data-action="edit-gear" data-item-id="{{gear.id}}">
                  <i class="fas fa-pen"></i>
                  {{localize "POKROLE.Actions.Edit"}}
                </button>
                <button type="button" data-action="delete-gear" data-item-id="{{gear.id}}">
                  <i class="fas fa-trash"></i>
                  {{localize "POKROLE.Actions.Delete"}}
                </button>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{else}}
        <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
        {{/if}}
      </section>

      <section class="sheet-section trainer-bio-panel">
        <h2>{{localize "POKROLE.Common.Biography"}}</h2>
        <textarea
          name="system.biography"
          rows="6"
          placeholder="{{localize 'POKROLE.Common.BiographyPlaceholder'}}"
        >{{system.biography}}</textarea>
      </section>

    </section>
  </section>
</form>
