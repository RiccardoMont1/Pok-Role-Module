<form class="{{cssClass}} pok-role-sheet trainer-sheet" autocomplete="off">
  <div class="trainer-sheet-shell trainer-theme-{{trainerGenderClass}}">
    <nav class="trainer-view-nav" aria-label="{{localize 'POKROLE.Trainer.ActiveEffects'}}">
      <button
        type="button"
        class="trainer-view-button is-active"
        data-action="switch-trainer-tab"
        data-tab="main"
        title="{{localize 'POKROLE.Trainer.MainSheetTab'}}"
        aria-label="{{localize 'POKROLE.Trainer.MainSheetTab'}}"
      >
        <i class="fas fa-id-card"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Trainer.MainSheetTab"}}</span>
      </button>
      <button
        type="button"
        class="trainer-view-button"
        data-action="switch-trainer-tab"
        data-tab="inventory"
        title="{{localize 'POKROLE.Trainer.InventoryTab'}}"
        aria-label="{{localize 'POKROLE.Trainer.InventoryTab'}}"
      >
        <i class="fas fa-box-open"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Trainer.InventoryTab"}}</span>
      </button>
      <button
        type="button"
        class="trainer-view-button"
        data-action="switch-trainer-tab"
        data-tab="effects"
        title="{{localize 'POKROLE.Effects.Tab'}}"
        aria-label="{{localize 'POKROLE.Effects.Tab'}}"
      >
        <i class="fas fa-wand-magic-sparkles"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Effects.Tab"}}</span>
      </button>
      <button
        type="button"
        class="trainer-view-button"
        data-action="switch-trainer-tab"
        data-tab="bio"
        title="{{localize 'POKROLE.Trainer.BioTab'}}"
        aria-label="{{localize 'POKROLE.Trainer.BioTab'}}"
      >
        <i class="fas fa-scroll"></i>
        <span class="trainer-view-label">{{localize "POKROLE.Trainer.BioTab"}}</span>
      </button>
    </nav>

    <div class="trainer-view-content">
      <div class="trainer-view-panel is-active" data-tab="main">
  <section class="trainer-id-card trainer-id-card-{{trainerGenderClass}}">
    <header class="trainer-id-header">
      <div class="trainer-id-league">
        <h1>POKEMON LEAGUE</h1>
        <p>{{localize "POKROLE.Trainer.MainSheetTab"}}</p>
      </div>
      <div class="trainer-id-controls">
        <label class="trainer-control trainer-control-rank">
          <span>{{localize "POKROLE.Trainer.CardRank"}}</span>
          <select name="system.cardRank">
            {{selectOptions trainerRankOptions selected=system.cardRank localize=true}}
          </select>
        </label>
        <label class="trainer-control trainer-control-gender">
          <span>{{localize "POKROLE.Trainer.Gender"}}</span>
          <div class="trainer-gender-select-wrap">
            <select name="system.gender">
              {{selectOptions trainerGenderOptions selected=trainerGender localize=true}}
            </select>
            <img class="trainer-gender-symbol" src="{{trainerGenderSymbolPath}}" alt="{{localize trainerGenderLabelPath}}" />
          </div>
        </label>
      </div>
    </header>

    <div class="trainer-id-body">
      <aside class="trainer-id-portrait">
        <div class="trainer-photo-frame">
          <img
            class="profile-img"
            src="{{actor.img}}"
            data-edit="img"
            title="{{actor.name}}"
          />
        </div>
        <div class="trainer-quick-actions">
          <button type="button" data-action="roll-initiative">
            <i class="fas fa-bolt"></i>
            {{localize "POKROLE.Actions.RollInitiative"}}
          </button>
          <button type="button" data-action="roll-combined">
            <i class="fas fa-dice"></i>
            {{localize "POKROLE.Actions.RollCombined"}}
          </button>
          <button type="button" data-action="reset-action-counter">
            <i class="fas fa-rotate-left"></i>
            {{localize "POKROLE.Actions.ResetActionCounter"}}
          </button>
        </div>
      </aside>

      <section class="trainer-id-info">
        <div class="trainer-card-fields">
          <label>
            <span>{{localize "POKROLE.Fields.Name"}}</span>
            <input
              name="name"
              type="text"
              value="{{actor.name}}"
              placeholder="{{localize 'POKROLE.Fields.Name'}}"
            />
          </label>
          <label>
            <span>{{localize "POKROLE.Trainer.Age"}}</span>
            <input
              type="number"
              name="system.age"
              value="{{system.age}}"
              min="0"
              max="120"
              data-dtype="Number"
            />
          </label>
          <label>
            <span>{{localize "POKROLE.Trainer.Player"}}</span>
            <input
              type="text"
              name="system.player"
              value="{{system.player}}"
            />
          </label>
          <label>
            <span>{{localize "POKROLE.Trainer.Concept"}}</span>
            <input
              type="text"
              name="system.concept"
              value="{{system.concept}}"
            />
          </label>
          <label>
            <span>{{localize "POKROLE.Trainer.Nature"}}</span>
            <input
              type="text"
              name="system.nature"
              value="{{system.nature}}"
            />
          </label>
          <label>
            <span>{{localize "POKROLE.Trainer.Money"}}</span>
            <input
              type="number"
              name="system.money"
              value="{{system.money}}"
              min="0"
              data-dtype="Number"
            />
          </label>
        </div>

        <div class="trainer-card-vitals">
          <label>
            <span>{{localize "POKROLE.Resources.HP"}}</span>
            <div class="pair-input">
              <input
                type="number"
                name="system.resources.hp.value"
                value="{{system.resources.hp.value}}"
                min="0"
                data-dtype="Number"
              />
              <span>/</span>
              <input
                type="number"
                name="system.resources.hp.max"
                value="{{system.resources.hp.max}}"
                min="1"
                data-dtype="Number"
              />
            </div>
          </label>
          <label>
            <span>{{localize "POKROLE.Resources.Will"}}</span>
            <div class="pair-input">
              <input
                type="number"
                name="system.resources.will.value"
                value="{{system.resources.will.value}}"
                min="0"
                data-dtype="Number"
              />
              <span>/</span>
              <input
                type="number"
                name="system.resources.will.max"
                value="{{system.resources.will.max}}"
                min="1"
                data-dtype="Number"
              />
            </div>
          </label>
          <label class="badges-field">
            <span>{{localize "POKROLE.Trainer.Badges"}}</span>
            <input
              type="hidden"
              name="system.badges"
              value="{{system.badges}}"
              data-dtype="Number"
            />
            <div class="track-bar compact badges-track">
              {{#each badgesTrack.slots as |slot|}}
              <button
                type="button"
                class="track-box {{#if slot.active}}is-active{{/if}}"
                data-action="set-track"
                data-track-field="system.badges"
                data-track-value="{{slot.value}}"
                data-track-min="{{../badgesTrack.min}}"
                data-track-max="{{../badgesTrack.max}}"
                title="{{localize 'POKROLE.Trainer.Badges'}} {{slot.value}}"
              ></button>
              {{/each}}
            </div>
          </label>
          <label class="trainer-pokedex-field">
            <span>{{localize "POKROLE.Trainer.SeenCaught"}}</span>
            <div class="pair-input">
              <input
                type="number"
                name="system.pokedex.seen"
                value="{{system.pokedex.seen}}"
                min="0"
                data-dtype="Number"
              />
              <span>/</span>
              <input
                type="number"
                name="system.pokedex.caught"
                value="{{system.pokedex.caught}}"
                min="0"
                data-dtype="Number"
              />
            </div>
          </label>
        </div>

        <p class="trainer-card-meta">
          <strong>{{localize "POKROLE.Combat.InitiativeScore"}}:</strong> {{initiativeScore}}
          |
          <strong>{{localize "POKROLE.Combat.BaseInitiativeScore"}}:</strong> {{baseInitiativeScore}}
          |
          <strong>{{localize "POKROLE.Combat.PainPenalty"}}:</strong> -{{painPenalty}}
          |
          <strong>{{localize "POKROLE.Combat.ActionNumber"}}:</strong>
          <input
            class="action-inline-input"
            type="number"
            name="system.combat.actionNumber"
            value="{{system.combat.actionNumber}}"
            min="1"
            max="5"
            data-dtype="Number"
          />
        </p>
      </section>
    </div>
  </section>

  <section class="trainer-main-grid">
    <section class="sheet-section trainer-stat-panel trainer-attributes-panel">
      <h2>{{localize "POKROLE.Attributes.Title"}}</h2>
      <div class="trainer-attribute-zones">
        <section class="trait-zone">
          <h3>{{localize "POKROLE.Attributes.PhysicalMental"}}</h3>
          <div class="trainer-stat-list">
            {{#each trainerPhysicalMentalAttributes as |attribute|}}
            <div class="trainer-stat-row">
              <label>{{localize attribute.label}}</label>
              <input
                type="hidden"
                name="{{attribute.fieldPath}}"
                value="{{attribute.value}}"
                data-dtype="Number"
              />
              <div class="track-bar compact">
                {{#each attribute.track.slots as |slot|}}
                <button
                  type="button"
                  class="track-box {{#if slot.active}}is-active{{/if}}"
                  data-action="set-track"
                  data-track-field="{{../fieldPath}}"
                  data-track-value="{{slot.value}}"
                  data-track-min="{{../track.min}}"
                  data-track-max="{{../track.max}}"
                  title="{{localize ../label}} {{slot.value}}"
                ></button>
                {{/each}}
              </div>
              <button
                type="button"
                class="icon-button"
                data-action="roll-attribute"
                data-attribute="{{attribute.key}}"
                title="{{localize 'POKROLE.Actions.RollAttribute'}}"
              >
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </section>

        <section class="trait-zone">
          <h3>{{localize "POKROLE.Attributes.Social"}}</h3>
          <div class="trainer-stat-list">
            {{#each trainerSocialAttributes as |attribute|}}
            <div class="trainer-stat-row">
              <label>{{localize attribute.label}}</label>
              <input
                type="hidden"
                name="{{attribute.fieldPath}}"
                value="{{attribute.value}}"
                data-dtype="Number"
              />
              <div class="track-bar compact">
                {{#each attribute.track.slots as |slot|}}
                <button
                  type="button"
                  class="track-box {{#if slot.active}}is-active{{/if}}"
                  data-action="set-track"
                  data-track-field="{{../fieldPath}}"
                  data-track-value="{{slot.value}}"
                  data-track-min="{{../track.min}}"
                  data-track-max="{{../track.max}}"
                  title="{{localize ../label}} {{slot.value}}"
                ></button>
                {{/each}}
              </div>
              <button
                type="button"
                class="icon-button"
                data-action="roll-attribute"
                data-attribute="{{attribute.key}}"
                title="{{localize 'POKROLE.Actions.RollAttribute'}}"
              >
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </section>
      </div>
    </section>

    <section class="sheet-section trainer-stat-panel trainer-skills-panel">
      <h2>{{localize "POKROLE.Skills.Title"}}</h2>
      <div class="trainer-stat-list">
        {{#each skillDefinitions as |skill|}}
        <div class="trainer-stat-row">
          <label>{{localize skill.label}}</label>
          <input
            type="hidden"
            name="system.skills.{{skill.key}}"
            value="{{skill.value}}"
            data-dtype="Number"
          />
          <div class="track-bar compact">
            {{#each skill.track.slots as |slot|}}
            <button
              type="button"
              class="track-box {{#if slot.active}}is-active{{/if}}"
              data-action="set-track"
              data-track-field="system.skills.{{../key}}"
              data-track-value="{{slot.value}}"
              data-track-min="{{../track.min}}"
              data-track-max="{{../track.max}}"
              title="{{localize ../label}} {{slot.value}}"
            ></button>
            {{/each}}
          </div>
          <button
            type="button"
            class="icon-button"
            data-action="roll-skill"
            data-skill="{{skill.key}}"
            title="{{localize 'POKROLE.Actions.RollSkill'}}"
          >
            <i class="fas fa-dice"></i>
          </button>
        </div>
        {{/each}}
      </div>

      <div class="trainer-extra-inline">
        <div class="section-title-row">
          <h3>{{localize "POKROLE.Trainer.ExtraSkills"}}</h3>
          <button type="button" data-action="add-extra-skill">
            <i class="fas fa-plus"></i>
            {{localize "POKROLE.Trainer.AddExtra"}}
          </button>
        </div>
        {{#if extraSkills.length}}
        <div class="trainer-extra-list">
          {{#each extraSkills as |extra|}}
          <div class="trainer-extra-row">
            <input
              type="text"
              name="system.extraSkills.{{extra.index}}.name"
              value="{{extra.name}}"
              placeholder="{{localize 'POKROLE.Trainer.ExtraName'}}"
            />
            <input
              type="hidden"
              name="system.extraSkills.{{extra.index}}.value"
              value="{{extra.value}}"
              data-dtype="Number"
            />
            <div class="track-bar compact">
              {{#each extra.track.slots as |slot|}}
              <button
                type="button"
                class="track-box {{#if slot.active}}is-active{{/if}}"
                data-action="set-track"
                data-track-field="system.extraSkills.{{../index}}.value"
                data-track-value="{{slot.value}}"
                data-track-min="{{../track.min}}"
                data-track-max="{{../track.max}}"
                title="{{../name}} {{slot.value}}"
              ></button>
              {{/each}}
            </div>
            <button
              type="button"
              class="icon-button danger"
              data-action="delete-extra-skill"
              data-extra-index="{{extra.index}}"
              title="{{localize 'POKROLE.Actions.Delete'}}"
            >
              <i class="fas fa-trash"></i>
            </button>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="empty-state">{{localize "POKROLE.Trainer.NoExtraSkills"}}</p>
        {{/if}}
      </div>
    </section>

  </section>
      </div>

      <div class="trainer-view-panel" data-tab="inventory">
        <section class="sheet-section trainer-inventory-section">
          <div class="section-title-row">
            <h2>{{localize "POKROLE.Trainer.InventoryTitle"}}</h2>
            <button type="button" class="inventory-add-button" data-action="create-gear">
              <i class="fas fa-plus"></i>
              {{localize "POKROLE.Actions.NewGear"}}
            </button>
          </div>

          <div class="trainer-pocket-grid">
            <section class="trainer-pocket-card pocket-potions">
              <header>
                <h3>{{localize "POKROLE.Gear.Pocket.Potions"}}</h3>
                <small>{{gearPocketPotions.length}} {{localize "POKROLE.Trainer.InventoryItems"}}</small>
              </header>
              {{#if gearPocketPotions.length}}
              <div class="trainer-pocket-items">
                {{#each gearPocketPotions as |gear|}}
                <article class="trainer-pocket-item" data-item-id="{{gear.id}}">
                  <div class="trainer-pocket-item-main">
                    <img src="{{gear.img}}" title="{{gear.name}}" />
                    <div>
                      <strong>{{gear.name}}</strong>
                      <small>{{gear.stockLabel}}</small>
                    </div>
                  </div>
                  <small class="trainer-pocket-effect">{{gear.effectsSummary}}</small>
                  <div class="move-actions">
                    <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                      <i class="fas fa-hand-sparkles"></i>
                    </button>
                    <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
                {{/each}}
              </div>
              {{else}}
              <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
              {{/if}}
            </section>

            <section class="trainer-pocket-card pocket-small">
              <header>
                <h3>{{localize "POKROLE.Gear.Pocket.Small"}}</h3>
                <small>{{gearPocketSmall.length}} {{localize "POKROLE.Trainer.InventoryItems"}}</small>
              </header>
              {{#if gearPocketSmall.length}}
              <div class="trainer-pocket-items">
                {{#each gearPocketSmall as |gear|}}
                <article class="trainer-pocket-item" data-item-id="{{gear.id}}">
                  <div class="trainer-pocket-item-main">
                    <img src="{{gear.img}}" title="{{gear.name}}" />
                    <div>
                      <strong>{{gear.name}}</strong>
                      <small>{{gear.stockLabel}}</small>
                    </div>
                  </div>
                  <small class="trainer-pocket-effect">{{gear.effectsSummary}}</small>
                  <div class="move-actions">
                    <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                      <i class="fas fa-hand-sparkles"></i>
                    </button>
                    <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
                {{/each}}
              </div>
              {{else}}
              <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
              {{/if}}
            </section>

            <section class="trainer-pocket-card pocket-main">
              <header>
                <h3>{{localize "POKROLE.Gear.Pocket.Main"}}</h3>
                <small>{{gearPocketMain.length}} {{localize "POKROLE.Trainer.InventoryItems"}}</small>
              </header>
              {{#if gearPocketMain.length}}
              <div class="trainer-pocket-items">
                {{#each gearPocketMain as |gear|}}
                <article class="trainer-pocket-item" data-item-id="{{gear.id}}">
                  <div class="trainer-pocket-item-main">
                    <img src="{{gear.img}}" title="{{gear.name}}" />
                    <div>
                      <strong>{{gear.name}}</strong>
                      <small>{{gear.stockLabel}}</small>
                    </div>
                  </div>
                  <small class="trainer-pocket-effect">{{gear.effectsSummary}}</small>
                  <div class="move-actions">
                    <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                      <i class="fas fa-hand-sparkles"></i>
                    </button>
                    <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
                {{/each}}
              </div>
              {{else}}
              <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
              {{/if}}
            </section>

            <section class="trainer-pocket-card pocket-badge">
              <header>
                <h3>{{localize "POKROLE.Gear.Pocket.Badge"}}</h3>
                <small>{{gearPocketBadge.length}} {{localize "POKROLE.Trainer.InventoryItems"}}</small>
              </header>
              {{#if gearPocketBadge.length}}
              <div class="trainer-pocket-items">
                {{#each gearPocketBadge as |gear|}}
                <article class="trainer-pocket-item" data-item-id="{{gear.id}}">
                  <div class="trainer-pocket-item-main">
                    <img src="{{gear.img}}" title="{{gear.name}}" />
                    <div>
                      <strong>{{gear.name}}</strong>
                      <small>{{gear.stockLabel}}</small>
                    </div>
                  </div>
                  <small class="trainer-pocket-effect">{{gear.effectsSummary}}</small>
                  <div class="move-actions">
                    <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                      <i class="fas fa-hand-sparkles"></i>
                    </button>
                    <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
                {{/each}}
              </div>
              {{else}}
              <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
              {{/if}}
            </section>

            <section class="trainer-pocket-card pocket-held">
              <header>
                <h3>{{localize "POKROLE.Gear.Pocket.Held"}}</h3>
                <small>{{gearPocketHeld.length}} {{localize "POKROLE.Trainer.InventoryItems"}}</small>
              </header>
              {{#if gearPocketHeld.length}}
              <div class="trainer-pocket-items">
                {{#each gearPocketHeld as |gear|}}
                <article class="trainer-pocket-item" data-item-id="{{gear.id}}">
                  <div class="trainer-pocket-item-main">
                    <img src="{{gear.img}}" title="{{gear.name}}" />
                    <div>
                      <strong>{{gear.name}}</strong>
                      <small>{{gear.stockLabel}}</small>
                    </div>
                  </div>
                  <small class="trainer-pocket-effect">{{gear.effectsSummary}}</small>
                  <div class="move-actions">
                    <button type="button" class="icon-button" data-action="use-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Use'}}">
                      <i class="fas fa-hand-sparkles"></i>
                    </button>
                    <button type="button" class="icon-button" data-action="edit-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Edit'}}">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="icon-button danger" data-action="delete-gear" data-item-id="{{gear.id}}" title="{{localize 'POKROLE.Actions.Delete'}}">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
                {{/each}}
              </div>
              {{else}}
              <p class="empty-state">{{localize "POKROLE.Gear.Empty"}}</p>
              {{/if}}
            </section>
          </div>
        </section>
      </div>

      <div class="trainer-view-panel" data-tab="effects">
  <section class="sheet-section trainer-conditions-panel">
    <h2>{{localize "POKROLE.Conditions.QuickTitle"}}</h2>
    <div class="condition-chip-grid">
      {{#each conditionChips as |condition|}}
      <button
        type="button"
        class="condition-chip {{#if condition.active}}is-active{{/if}}"
        data-action="toggle-condition-chip"
        data-condition-key="{{condition.key}}"
      >
        <img src="{{condition.icon}}" alt="{{localize condition.labelPath}}" />
        <span>{{localize condition.labelPath}}</span>
      </button>
      {{/each}}
    </div>
  </section>

  <section class="sheet-section actor-effects-panel">
    <div class="section-title-row">
      <h2>{{localize "POKROLE.Effects.ConfiguredTitle"}}</h2>
      <div class="button-row">
        <button type="button" data-action="add-actor-effect">
          <i class="fas fa-plus"></i>
          {{localize "POKROLE.Effects.Add"}}
        </button>
      </div>
    </div>
    <div class="effects-group-grid">
      <section class="effects-group">
        <h3>{{localize "POKROLE.Effects.TemporaryTitle"}}</h3>
        <div class="temporary-effects-list">
          {{#if embeddedTemporaryEffects.length}}
          {{#each embeddedTemporaryEffects as |effect|}}
          <article class="temporary-effect-row">
            <div class="temporary-effect-main">
              <strong>{{effect.name}}</strong>
              <small>{{effect.durationLabel}} | {{effect.statuses}}</small>
              <small>{{effect.origin}}</small>
            </div>
            <div class="move-actions">
              <button
                type="button"
                class="icon-button"
                data-action="edit-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Edit'}}"
              >
                <i class="fas fa-pen"></i>
              </button>
              <button
                type="button"
                class="icon-button"
                data-action="toggle-embedded-effect-disabled"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Effects.Disable'}}"
              >
                <i class="fas fa-toggle-off"></i>
              </button>
              <button
                type="button"
                class="icon-button danger"
                data-action="delete-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Delete'}}"
              >
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </article>
          {{/each}}
          {{/if}}
          {{#if temporaryEffects.length}}
          {{#each temporaryEffects as |effect|}}
          <article class="temporary-effect-row">
            <div class="temporary-effect-main">
              <strong>{{effect.label}}</strong>
              <small>{{effect.sourceLabel}} | {{effect.durationLabel}}</small>
            </div>
            <button
              type="button"
              class="icon-button danger temporary-effect-remove"
              data-action="remove-temporary-effect"
              data-effect-id="{{effect.id}}"
              title="{{localize 'POKROLE.TemporaryEffects.Remove'}}"
            >
              <i class="fas fa-trash"></i>
            </button>
          </article>
          {{/each}}
          {{/if}}
          {{#unless embeddedTemporaryEffects.length}}
          {{#unless temporaryEffects.length}}
          <p class="empty-state">{{localize "POKROLE.Effects.TemporaryEmpty"}}</p>
          {{/unless}}
          {{/unless}}
        </div>
      </section>

      <section class="effects-group">
        <h3>{{localize "POKROLE.Effects.PassiveTitle"}}</h3>
        <div class="temporary-effects-list">
          {{#if embeddedPassiveEffects.length}}
          {{#each embeddedPassiveEffects as |effect|}}
          <article class="temporary-effect-row">
            <div class="temporary-effect-main">
              <strong>{{effect.name}}</strong>
              <small>{{effect.durationLabel}} | {{effect.statuses}}</small>
              <small>{{effect.origin}}</small>
            </div>
            <div class="move-actions">
              <button
                type="button"
                class="icon-button"
                data-action="edit-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Edit'}}"
              >
                <i class="fas fa-pen"></i>
              </button>
              <button
                type="button"
                class="icon-button"
                data-action="toggle-embedded-effect-disabled"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Effects.Disable'}}"
              >
                <i class="fas fa-toggle-off"></i>
              </button>
              <button
                type="button"
                class="icon-button danger"
                data-action="delete-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Delete'}}"
              >
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </article>
          {{/each}}
          {{else}}
          <p class="empty-state">{{localize "POKROLE.Effects.PassiveEmpty"}}</p>
          {{/if}}
        </div>
      </section>

      <section class="effects-group">
        <h3>{{localize "POKROLE.Effects.DisabledTitle"}}</h3>
        <div class="temporary-effects-list">
          {{#if embeddedDisabledEffects.length}}
          {{#each embeddedDisabledEffects as |effect|}}
          <article class="temporary-effect-row">
            <div class="temporary-effect-main">
              <strong>{{effect.name}}</strong>
              <small>{{effect.durationLabel}} | {{effect.statuses}}</small>
              <small>{{effect.origin}}</small>
            </div>
            <div class="move-actions">
              <button
                type="button"
                class="icon-button"
                data-action="edit-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Edit'}}"
              >
                <i class="fas fa-pen"></i>
              </button>
              <button
                type="button"
                class="icon-button"
                data-action="toggle-embedded-effect-disabled"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Effects.Enable'}}"
              >
                <i class="fas fa-toggle-on"></i>
              </button>
              <button
                type="button"
                class="icon-button danger"
                data-action="delete-embedded-effect"
                data-effect-id="{{effect.id}}"
                title="{{localize 'POKROLE.Actions.Delete'}}"
              >
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </article>
          {{/each}}
          {{else}}
          <p class="empty-state">{{localize "POKROLE.Effects.DisabledEmpty"}}</p>
          {{/if}}
        </div>
      </section>
    </div>
  </section>
      </div>

      <div class="trainer-view-panel" data-tab="bio">
  <section class="sheet-section trainer-bio-panel">
    <h2>{{localize "POKROLE.Trainer.InfoTitle"}}</h2>
    <div class="trainer-identity-grid">
      <label>
        <span>{{localize "POKROLE.Trainer.Role"}}</span>
        <input type="text" name="system.role" value="{{system.role}}" placeholder="{{localize 'POKROLE.Trainer.RolePlaceholder'}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Player"}}</span>
        <input type="text" name="system.player" value="{{system.player}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Concept"}}</span>
        <input type="text" name="system.concept" value="{{system.concept}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Trainer.Nature"}}</span>
        <input type="text" name="system.nature" value="{{system.nature}}" />
      </label>
    </div>
  </section>

  <section class="sheet-section trainer-bio-panel">
    <h2>{{localize "POKROLE.Common.Biography"}}</h2>
    <textarea
      name="system.biography"
      rows="12"
      placeholder="{{localize 'POKROLE.Common.BiographyPlaceholder'}}"
    >{{system.biography}}</textarea>
  </section>
      </div>
    </div>
  </div>
</form>
