<form class="{{cssClass}} pok-role-sheet reference-sheet ability-sheet" autocomplete="off">
  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{item.img}}"
      data-edit="img"
      title="{{item.name}}"
    />
    <div class="header-fields">
      <h1 class="charname">
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="{{localize 'POKROLE.Playable.Ability.Name'}}"
        />
      </h1>
    </div>
  </header>

  <section class="sheet-section">
    <div class="form-grid two-col">
      <label>
        <span>{{localize "POKROLE.Playable.Ability.Type.Label"}}</span>
        <select name="system.abilityType">
          {{selectOptions abilityTypeOptions selected=system.abilityType localize=true}}
        </select>
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Ability.Frequency"}}</span>
        <input type="text" name="system.frequency" value="{{system.frequency}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Ability.Trigger"}}</span>
        <input type="text" name="system.trigger" value="{{system.trigger}}" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Ability.Target"}}</span>
        <input type="text" name="system.target" value="{{system.target}}" />
      </label>
    </div>
  </section>

  <section class="sheet-section">
    <h2>{{localize "POKROLE.Playable.Ability.Effect"}}</h2>
    <textarea name="system.effect" rows="6">{{system.effect}}</textarea>
  </section>

  <section class="sheet-section">
    <h2>{{localize "POKROLE.Common.Description"}}</h2>
    <textarea name="system.description" rows="6">{{system.description}}</textarea>
  </section>
</form>
