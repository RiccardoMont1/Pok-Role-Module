<form class="{{cssClass}} pok-role-sheet gear-sheet" autocomplete="off">
  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{item.img}}"
      data-edit="img"
      title="{{item.name}}"
    />
    <div class="header-fields">
      <h1 class="charname">
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="{{localize 'POKROLE.Gear.Name'}}"
        />
      </h1>
    </div>
  </header>

  {{!-- Common fields: Category, Pocket, Quantity --}}
  <section class="sheet-section">
    <div class="form-grid two-col">
      <label>
        <span>{{localize "POKROLE.Gear.Category.Label"}}</span>
        <select name="system.category">
          {{selectOptions gearCategoryOptions selected=system.category localize=true}}
        </select>
      </label>
      <label>
        <span>{{localize "POKROLE.Gear.Pocket.Label"}}</span>
        <select name="system.pocket">
          {{selectOptions gearPocketOptions selected=system.pocket localize=true}}
        </select>
      </label>
      {{#unless isKey}}
      <label>
        <span>{{localize "POKROLE.Gear.Target.Label"}}</span>
        <select name="system.target">
          {{selectOptions gearTargetOptions selected=system.target localize=true}}
        </select>
      </label>
      {{/unless}}
      <label>
        <span>{{localize "POKROLE.Gear.Quantity"}}</span>
        <input
          type="number"
          name="system.quantity"
          value="{{system.quantity}}"
          min="0"
          max="999"
          data-dtype="Number"
        />
      </label>
    </div>
  </section>

  {{!-- POKEBALL --}}
  {{#if isPokeball}}
  <section class="sheet-section">
    <h2>{{localize "POKROLE.Gear.Pokeball.Title"}}</h2>
    <div class="form-grid two-col">
      <label>
        <span>{{localize "POKROLE.Gear.Pokeball.SealPower"}}</span>
        <input
          type="number"
          name="system.pokeball.sealPower"
          value="{{system.pokeball.sealPower}}"
          min="0"
          max="20"
          data-dtype="Number"
        />
      </label>
      <label>
        <span>{{localize "POKROLE.Gear.Pokeball.SpecialEffect"}}</span>
        <select name="system.pokeball.specialEffect">
          {{selectOptions pokeballEffectOptions selected=system.pokeball.specialEffect localize=true}}
        </select>
      </label>
    </div>
    <div class="checkbox-grid">
      <label class="checkbox-row">
        <input type="checkbox" name="system.consumable" {{checked system.consumable}} />
        <span>{{localize "POKROLE.Gear.Consumable"}}</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" name="system.canUseInBattle" {{checked system.canUseInBattle}} />
        <span>{{localize "POKROLE.Gear.UseInBattle"}}</span>
      </label>
    </div>
  </section>
  {{/if}}

  {{!-- HEALING (Cura) --}}
  {{#if isHealing}}
  <section class="sheet-section">
    <div class="form-grid two-col">
      <label>
        <span>{{localize "POKROLE.Gear.UnitsCurrent"}}</span>
        <input type="number" name="system.units.value" value="{{system.units.value}}" min="0" max="99" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Gear.UnitsMax"}}</span>
        <input type="number" name="system.units.max" value="{{system.units.max}}" min="0" max="99" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Gear.HealHp"}}</span>
        <input type="number" name="system.heal.hp" value="{{system.heal.hp}}" min="0" max="50" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Gear.HealLethal"}}</span>
        <input type="number" name="system.heal.lethal" value="{{system.heal.lethal}}" min="0" max="50" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Healing.Category.Label"}}</span>
        <select name="system.heal.battleHealingCategory">
          {{selectOptions gearHealingCategoryOptions selected=system.heal.battleHealingCategory localize=true}}
        </select>
      </label>
    </div>
  </section>
  <section class="sheet-section">
    <h2>{{localize "POKROLE.Gear.Flags"}}</h2>
    <div class="checkbox-grid">
      <label class="checkbox-row">
        <input type="checkbox" name="system.consumable" {{checked system.consumable}} />
        <span>{{localize "POKROLE.Gear.Consumable"}}</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" name="system.canUseInBattle" {{checked system.canUseInBattle}} />
        <span>{{localize "POKROLE.Gear.UseInBattle"}}</span>
