<form class="{{cssClass}} pok-role-sheet reference-sheet weather-sheet" autocomplete="off">
  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{item.img}}"
      data-edit="img"
      title="{{item.name}}"
    />
    <div class="header-fields">
      <h1 class="charname">
        <input
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="{{localize 'POKROLE.Playable.Weather.Name'}}"
        />
      </h1>
    </div>
  </header>

  <section class="sheet-section">
    <div class="form-grid two-col">
      <label>
        <span>{{localize "POKROLE.Playable.Weather.Category.Label"}}</span>
        <select name="system.category">
          {{selectOptions weatherCategoryOptions selected=system.category localize=true}}
        </select>
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Weather.Duration"}}</span>
        <input type="number" name="system.duration" value="{{system.duration}}" min="0" max="999" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Weather.AccuracyMod"}}</span>
        <input type="number" name="system.accuracyModifier" value="{{system.accuracyModifier}}" min="-6" max="6" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Weather.DamageMod"}}</span>
        <input type="number" name="system.damageModifier" value="{{system.damageModifier}}" min="-6" max="6" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Weather.EndRoundDamage"}}</span>
        <input type="number" name="system.endOfRoundDamage" value="{{system.endOfRoundDamage}}" min="0" max="20" data-dtype="Number" />
      </label>
      <label>
        <span>{{localize "POKROLE.Playable.Weather.AffectedTypes"}}</span>
        <input type="text" name="system.affectedTypes" value="{{system.affectedTypes}}" />
      </label>
    </div>
  </section>

  <section class="sheet-section">
    <h2>{{localize "POKROLE.Playable.Weather.Effect"}}</h2>
    <textarea name="system.effect" rows="6">{{system.effect}}</textarea>
  </section>

  <section class="sheet-section">
    <h2>{{localize "POKROLE.Common.Description"}}</h2>
    <textarea name="system.description" rows="6">{{system.description}}</textarea>
  </section>
</form>
